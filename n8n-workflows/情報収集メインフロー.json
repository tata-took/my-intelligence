      ]
    },
    {
      "parameters": {
        "jsCode": "// 収集結果のサマリーを作成（LINE通知用）\nconst items = $input.all();\nconst today = new Date().toISOString().split('T')[0];\n\nconst summary = `📊 情報収集完了 ${today}\\n\\n収集件数: ${items.length}件\\n\\n最新記事Top3:\\n${items.slice(0, 3).map((item, i) => `${i + 1}. ${item.json.title}`).join('\\n')}\\n\\n詳細はObsidianで確認してください`;\n\nreturn [{ json: { summary, count: items.length } }];"
      },
