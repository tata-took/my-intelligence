    {
      "parameters": {
        "jsCode": "// 記事データを整形する\nconst items = $input.all();\nconst seen = new Set();\nconst formatted = [];\n\nfor (const item of items) {\n  const link = item.json.link || item.json.url || '';\n  \n  // 重複除去\n  if (seen.has(link)) continue;\n  seen.add(link);\n  \n  formatted.push({\n    json: {\n      title: item.json.title || 'タイトルなし',\n      link: link,\n      date: item.json.pubDate || item.json.date || new Date().toISOString(),\n      summary: item.json.contentSnippet || item.json.content || item.json.description || '',\n      source: item.json.feedUrl || ''\n    }\n  });\n}\n\nreturn formatted;"
      },
      "id": "3d30887e-f613-4ada-8bed-f9d0586619cf",
      "name": "整形・重複除去",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -544,
        -48
      ]
    },
    {
      "parameters": {
        "jsCode": "// sources.ymlのキーワードでフィルタリング\nconst keywords = [\n  'AI', 'エージェント', 'LLM', 'Claude', 'GPT',\n  'GitHub', 'Python', 'n8n', 'Obsidian', '自動化'\n];\n\nconst items = $input.all();\nconst filtered = items.filter(item => {\n  const text = (\n    (item.json.title || '') + ' ' +\n    (item.json.summary || '')\n  ).toLowerCase();\n  return keywords.some(kw => text.includes(kw.toLowerCase()));\n});\n\nreturn filtered.length > 0 ? filtered : items;"
      },
      "id": "1d0c9fb1-7511-45fc-ae1b-9e6d9460a07e",
      "name": "キーワードフィルター",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -320,
        -48
      ]
    },
    {
      "parameters": {
        "jsCode": "// Obsidian用のMarkdownを生成する\nconst items = $input.all();\nconst today = new Date().toISOString().split('T')[0];\n\nconst results = items.map((item, index) => {\n  const title = item.json.title || 'タイトルなし';\n  const link = item.json.link || '';\n  const date = item.json.date || today;\n  const summary = item.json.summary || '';\n  const source = item.json.source || '';\n  \n  const safeTitle = title\n    .replace(/[\\\\/\\:*?\"<>|]/g, '')\n    .substring(0, 50);\n  \n  const markdown = `---\\ntitle: \"${title}\"\\ndate: ${today}\\nimportance: \\ntags: []\\nrelated_people: []\\nrelated_companies: []\\nrelated_tech: []\\nsource: ${source}\\nurl: ${link}\\n---\\n\\n## 📄 要約\\n${summary}\\n\\n## 🔗 元記事\\n${link}\\n\\n## ⚡ 意外な繋がり\\n（AIが後で分析）\\n\\n## 💡 自分のメモ\\n`;\n  \n  return {\n    json: {\n      filename: `${today}_${safeTitle}.md`,\n      content: markdown,\n      title: title,\n      link: link\n    }\n  };\n});\n\nreturn results;"
      },
      "id": "104ac5e5-344d-4e54-8c82-d253e6eba1e4",
      "name": "Markdown生成",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -96,
